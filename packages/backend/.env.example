# ── SigmaBet Core ──────────────────────────────────────
PORT=3000

# ── AI Generation & Resolution ────────────────────────
# Set to "true" to use Google OAuth 2.0 CLI login
USE_LOCAL_OAUTH=true
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o

# Backend Wallet (Used for on-chain market creation and resolution)
# This wallet must have Base Sepolia ETH and tokens for initial liquidity.
WALLET_PRIVATE_KEY=0x...

RPC_URL=https://sepolia.base.org
OPENBET_FACTORY_ADDRESS=0x...

# ── Supabase ──────────────────────────────────────────
CLAWDBET_SUPABASE_URL=https://your-project.supabase.co
CLAWDBET_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Market Fees ───────────────────────────────────────
# Default fee charged to the user for market generation (in USDC)
GENERATION_FEE_USDC=5
# Commission % for the platform (integer, e.g., 10 for 10%)
PLATFORM_COMMISSION_PCT=10
